---

<section id="profiles" class="section">
  <div class="container">
    <div class="section-header">
      <span class="section-label reveal">Find me online</span>
      <h2 class="section-title reveal reveal-delay-1">Profiles & Publications</h2>
    </div>

    <div class="profiles-grid">
      {profiles.map((profile, i) => (
        <a href={profile.url} target="_blank" rel="noopener noreferrer" class={`profile-card glass-card reveal reveal-delay-${(i % 4) + 1}`}>
          <div class="profile-icon">
            <Fragment set:html={getProfileIcon(profile.icon)} />
          </div>
          <h3 class="profile-name">{profile.name}</h3>
          <p class="profile-desc">{profile.description}</p>
          <span class="profile-arrow">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17l9.2-9.2M17 17V7H7"/></svg>
          </span>
        </a>
      ))}
    </div>

    <div class="publications-section">
      <h3 class="pub-heading reveal">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
        Publications
      </h3>
      <div class="pub-list">
        {publications.map((pub, i) => (
          <div class={`pub-card glass-card reveal reveal-delay-${i + 1}`}>
            <h4 class="pub-title">{pub.title}</h4>
            <span class="pub-venue">{pub.venue}</span>
            <p class="pub-desc">{pub.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .profiles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 20px;
    margin-bottom: 64px;
  }

  .profile-card {
    padding: 28px;
    text-align: center;
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .profile-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--accent-gradient);
    transform: scaleX(0);
    transition: transform var(--transition-base);
  }

  .profile-card:hover::before {
    transform: scaleX(1);
  }

  .profile-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-md);
    background: rgba(6, 182, 212, 0.08);
    color: var(--accent-cyan);
    transition: all var(--transition-base);
  }

  .profile-card:hover .profile-icon {
    background: var(--accent-gradient);
    color: #fff;
    transform: scale(1.05);
  }

  .profile-name {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 6px;
    color: var(--text-primary);
  }

  .profile-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: 12px;
  }

  .profile-arrow {
    display: inline-flex;
    color: var(--text-muted);
    transition: all var(--transition-fast);
  }

  .profile-card:hover .profile-arrow {
    color: var(--accent-cyan);
    transform: translate(4px, -4px);
  }

  .publications-section {
    max-width: 800px;
    margin: 0 auto;
  }

  .pub-heading {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 24px;
    color: var(--text-primary);
  }

  .pub-heading svg {
    color: var(--accent-cyan);
  }

  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .pub-card {
    padding: 24px;
  }

  .pub-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 6px;
  }

  .pub-venue {
    font-size: 0.8rem;
    color: var(--accent-cyan);
    font-weight: 500;
    display: block;
    margin-bottom: 10px;
  }

  .pub-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  @media (max-width: 480px) {
    .profiles-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .profile-card {
      padding: 20px 16px;
    }

    .profile-desc {
      display: none;
    }
  }
</style>

